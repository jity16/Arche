# macOS
.DS_Store

# Python bytecode / cache
__pycache__/
*.py[cod]
*$py.class

# Build / packaging artifacts
build/
dist/
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Runtime outputs and logs (controller/agents)
.runtime/
outputs/
**/multiagent_log.json
**/bounded_closed_loop_result.json
**/closed_loop_error.json
**/closed_loop_resume_error.json
**/waiting_gaussian_jobs_state.json

# Test generated artifacts
tests/temp/*
tests/outputs/*
tests/reports/*

# Agent-generated runtime artifacts
src/chemistry_multiagent/agents/outputs/*

# Keep intentional placeholder directories/files trackable
!tests/temp/
!tests/temp/.gitkeep
!tests/outputs/
!tests/outputs/.gitkeep
!tests/reports/
!tests/reports/.gitkeep
!src/chemistry_multiagent/agents/outputs/
!src/chemistry_multiagent/agents/outputs/.gitkeep

# Gaussian/runtime job state artifacts
.gaussian_job_state_*.json
*.chk
*.fchk
*.rwf
*.int
*.d2e
*.fort
fort.*
# execution_agent 运行副产物：作业目录(gaussian_jobs/)、工具生成的初始结构(<mol>_initial.sdf)、
# generate_gaussian_code 生成的 Gaussian 输入(*.gjf)
gaussian_jobs/
*_initial.sdf
*.gjf

# retrieval 运行副产物：下载的论文 PDF(papers/) 与构建的向量索引(index/)——运行时生成，不入库
papers/
index/

# 前端 TypeScript 增量构建缓存
*.tsbuildinfo
frontend/.test-tmp/

# Nested VCS metadata from vendored snapshots
**/.git/

# Notebook and editor artifacts
.ipynb_checkpoints/
.vscode/
.idea/

# === 书安OS 内置资产体积裁剪（与 .dockerignore 对齐） ===
# vendored 第三方二进制工具链：数百 MB，运行服务不消费；真实模式由部署环境提供，
# 经环境变量定位（MULTIWFN_PATH / ARCHE_TOOLPOOL_PATH / GAUSSIAN_*，见 chart/values.yaml）。
# 不纳入 monorepo，避免把二进制塞进版本库。
src/chemistry_multiagent/tools/cmake-3.30.4-linux-x86_64/
src/chemistry_multiagent/tools/openbabel-openbabel-3-1-1/
src/chemistry_multiagent/tools/ash-NEW/
src/chemistry_multiagent/tools/Multiwfn_3.8_dev_bin_Linux_noGUI/
src/chemistry_multiagent/tools/23_TSPipeline/

# 研究数据 / 论文 / 评测集 / 大体积夹具：运行不消费，不纳入版本库
dataset/
supplementary/
tests/inputs/

# 本地实参 / 密钥（LLM endpoint key 等）—— 绝不入库
.env.local
.env*.local
.arche-runtime.json
